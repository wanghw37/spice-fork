rule summary:
    input:
        selection_points=expand(
            os.path.join(analysis_dir, 'final_selection_points', '{chrom}.pickle'),
            chrom=CHROMOSOMES
        )
    output:
        summary=os.path.join(analysis_dir, 'summary.txt')
    run:
        logger = spice.utils.get_logger('summary', load_config=False)
        logger.info(f'Generating summary for {name}')
        
        with open(output.summary, 'w') as f:
            f.write(f'Loci Detection De-Novo Summary\n')
            f.write(f'Project: {name}\n')
            f.write(f'Analysis directory: {analysis_dir}\n')
            f.write(f'Chromosomes processed: {len(CHROMOSOMES)}\n')
            f.write(f'Chromosomes: {", ".join(CHROMOSOMES)}\n')
            f.write(f'\nFinal selection points saved to: {analysis_dir}/final_selection_points/\n')
        
        logger.info(f'Summary written to {output.summary}')
