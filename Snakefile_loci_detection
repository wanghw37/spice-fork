"""
Snakemake workflow for loci detection (de-novo mode).
Processes chromosomes in parallel to detect recurrent copy-number loci.

Run locally:
  SPICE_CONFIG=/path/to/config.yaml snakemake -s Snakefile_loci_detection --verbose -c4 --rerun-triggers mtime

Run on Slurm:
  SPICE_CONFIG=/path/to/config.yaml snakemake -s Snakefile_loci_detection --rerun-triggers mtime --verbose --slurm -j250 --keep-going
"""

import os
import sys
import pandas as pd

# Load config from environment variable
config_path = os.environ.get('SPICE_CONFIG', 'config.yaml')
if not os.path.exists(config_path):
    raise FileNotFoundError(f"Config file not found: {config_path}")

# Import SPICE config handling
sys.path.insert(0, os.path.dirname(__file__))
import spice
spice.load_config(config_path)
from spice import config
from spice.utils import open_pickle, save_pickle
from spice.data_loaders import load_final_events
from spice.main_loci_functions import process_final_events_for_loci_routines

# Extract key paths from config
name = config['name']
results_dir = os.path.join(config['directories']['results_dir'], name)

# Match the CLI's loci_results_dir exactly so combine_loci() can find outputs
loci_results_dir = os.path.join(results_dir, 'loci_of_selection')

# Per-chromosome results go into the 'detection' subdirectory (mode='detection')
# This matches combine_loci(mode='detection') path: loci_results_dir/detection/{chrom}/
analysis_dir = os.path.join(loci_results_dir, 'detection')

# Read loci_detection parameters from config (filled from default_config.yaml defaults)
loci_cfg = config['loci_detection']
N_bootstrap = loci_cfg.get('N_bootstrap', 1000)
N_kernel    = loci_cfg.get('N_kernel', 100_000)

# Load final events from TSV (event_inference writes final_events.tsv, not .pickle)
final_events_tsv = os.path.join(results_dir, 'final_events.tsv')
if not os.path.exists(final_events_tsv):
    raise FileNotFoundError(
        f"final_events.tsv not found at {final_events_tsv}. Run event_inference first.")

# Apply the same preprocessing as the CLI does before per-chrom analysis
_raw_events = load_final_events()
final_events_df = process_final_events_for_loci_routines(
    final_events_df=_raw_events,
    remove_plateaus=loci_cfg.get('remove_plateaus', True),
    remove_chrY=loci_cfg.get('remove_chrY', True),
    drop_duplicates=loci_cfg.get('drop_duplicates', True),
    use_observed_centromeres=loci_cfg.get('use_observed_centromeres', True),
)
CHROMOSOMES = sorted(final_events_df['chrom'].unique())
if not CHROMOSOMES:
    raise ValueError(
        "No chromosomes found in final_events_df after preprocessing. "
        "Check that final_events.tsv is not empty and preprocessing parameters are correct."
    )

print(f"Loci detection workflow for {name}")
print(f"Processing chromosomes: {CHROMOSOMES}")
print(f"N_bootstrap={N_bootstrap}, N_kernel={N_kernel}")


# Rule to define all outputs
rule all:
    input:
        os.path.join(loci_results_dir, 'final_loci_detection.tsv'),
        os.path.join(loci_results_dir, 'summary.txt')


rule bootstrap_signal:
    output:
        bootstrap=os.path.join(loci_results_dir, 'signal_bootstrap', '{chrom}_N_' + str(N_bootstrap) + '.pickle')
    log:
        os.path.join(loci_results_dir, 'logs', 'bootstrap_signal_{chrom}.log')
    run:
        import spice
        from spice.utils import get_logger
        from spice.tsg_og.signal_bootstrap import bootstrap_sampling_of_signal

        logger = get_logger(f'bootstrap_signal_{wildcards.chrom}', load_config=False)
        logger.info(f'Bootstrapping signal for {wildcards.chrom} (N={N_bootstrap})')

        bootstrap_sampling_of_signal(
            cur_chrom=wildcards.chrom,
            final_events_df=final_events_df,
            N_bootstrap=N_bootstrap,
            calc_new_filename=output.bootstrap
        )

        logger.info(f'Bootstrap complete for {wildcards.chrom}')


rule collect_data_per_length_scale:
    input:
        bootstrap=os.path.join(loci_results_dir, 'signal_bootstrap', '{chrom}_N_' + str(N_bootstrap) + '.pickle')
    output:
        data_file=os.path.join(loci_results_dir, 'data_per_length_scale', '{chrom}.pickle')
    log:
        os.path.join(loci_results_dir, 'logs', 'collect_data_per_length_scale_{chrom}.log')
    run:
        import spice
        from spice.utils import get_logger
        from spice.tsg_og.detection import collect_data_per_length_scale

        logger = get_logger(f'collect_data_per_length_scale_{wildcards.chrom}', load_config=False)
        logger.info(f'Collecting data per length scale for {wildcards.chrom}')

        collect_data_per_length_scale(
            final_events_df,
            wildcards.chrom,
            loci_results_dir=loci_results_dir,
            N_bootstrap=N_bootstrap,
            N_kernel=N_kernel,
            calc_new_filename=output.data_file
        )

        logger.info(f'Saved data per length scale to {output.data_file}')


rule detection:
    input:
        data_file=os.path.join(loci_results_dir, 'data_per_length_scale', '{chrom}.pickle')
    output:
        loci=os.path.join(analysis_dir, '{chrom}', 'detection.pickle')
    log:
        os.path.join(loci_results_dir, 'logs', 'detection_{chrom}.log')
    run:
        import spice
        from spice.utils import get_logger, open_pickle
        from spice.tsg_og.detection import detect_tsgs_ogs_for_all_length_scales

        logger = get_logger(f'detection_{wildcards.chrom}', load_config=False)
        logger.info(f'Running detection for {wildcards.chrom}')

        data_per_length_scale = open_pickle(input.data_file)

        detect_tsgs_ogs_for_all_length_scales(
            cur_chrom=wildcards.chrom,
            blocked_distance_th=2e5,
            force_up_down=True,
            N_iterations_base=3000,
            max_N_iterations=20_000,
            final_N_iterations=250_000,
            N_loci=100,
            max_fitness=1_000,
            length_scales_for_residuals=[0, 1, 2, 3, 4, 5, 6, 7],
            data_per_length_scale=data_per_length_scale,
            calc_new_filename=output.loci
        )

        logger.info(f'Detection complete for {wildcards.chrom}')


rule flipping:
    input:
        data_file=os.path.join(loci_results_dir, 'data_per_length_scale', '{chrom}.pickle'),
        detection=os.path.join(analysis_dir, '{chrom}', 'detection.pickle')
    output:
        flipped=os.path.join(analysis_dir, '{chrom}', 'flipping.pickle')
    log:
        os.path.join(loci_results_dir, 'logs', 'flipping_{chrom}.log')
    run:
        import spice
        from spice.utils import get_logger, open_pickle
        from spice.tsg_og.detection import flip_up_down_assignment

        logger = get_logger(f'flipping_{wildcards.chrom}', load_config=False)
        logger.info(f'Running flipping for {wildcards.chrom}')

        data_per_length_scale = open_pickle(input.data_file)
        # detect_tsgs_ogs_for_all_length_scales returns a 3-tuple; extract selection points
        detection_tuple = open_pickle(input.detection)
        detection_result = detection_tuple[0]

        flip_up_down_assignment(
            cur_chrom=wildcards.chrom,
            final_selection_points=detection_result,
            data_per_length_scale=data_per_length_scale,
            n_neighbors=10,
            N_iterations=11_000,
            N_iterations_single=1_000,
            calc_new_filename=output.flipped
        )

        logger.info(f'Flipping complete for {wildcards.chrom}')


