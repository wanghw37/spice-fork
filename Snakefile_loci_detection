rule within_ci_filtering:
    input:
        data_file=os.path.join(loci_results_dir, 'data_per_length_scale', '{chrom}.pickle'),
        ranked=os.path.join(analysis_dir, '{chrom}', 'ranking.pickle')
    output:
        filtered=os.path.join(analysis_dir, '{chrom}', 'within_ci_filtering.pickle')
    log:
        os.path.join(loci_results_dir, 'logs', 'within_ci_filtering_{chrom}.log')
    run:
        import spice
        from spice.utils import get_logger, open_pickle
        from spice.tsg_og.detection import within_ci_fitness_filter

        logger = get_logger(f'within_ci_filtering_{wildcards.chrom}', load_config=False)
        logger.info(f'Running within_ci_filtering for {wildcards.chrom}')

        data_per_length_scale = open_pickle(input.data_file)
        # rank_loci returns optimized_locus_iterations: list of (selection_points, loss, cluster_i)
        # Extract the final selection points from the last iteration
        ranking_locus_iterations = open_pickle(input.ranked)
        ranked_result = ranking_locus_iterations[-1][0]

        within_ci_fitness_filter(
            cur_chrom=wildcards.chrom,
            ranked_selection_points=ranked_result,
            data_per_length_scale=data_per_length_scale,
            show_progress=False,
            log_progress=True,
            N_iterations_optimization=loci_cfg.get('within_ci_N_iterations', 10_000),
            calc_new_filename=output.filtered
        )

        logger.info(f'Within CI filtering complete for {wildcards.chrom}')


rule limiting:
