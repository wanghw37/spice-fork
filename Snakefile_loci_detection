            show_progress=False,
            loss_threshold=0.125,
            within_ci_threshold=0.01,
            ls_i_to_check=(6, 7),
            calc_new_filename=output.final_limited
        )

        logger.info(f'Final limiting complete for {wildcards.chrom}')


rule final_selection_points:
    input:
        final_limited=os.path.join(analysis_dir, '{chrom}', 'final_limiting.pickle')
    output:
        selection_points=os.path.join(analysis_dir, '{chrom}', 'final_selection_points.pickle')
    log:
        os.path.join(loci_results_dir, 'logs', 'final_selection_points_{chrom}.log')
    run:
        import spice
        from spice.utils import get_logger, open_pickle, save_pickle
        from spice.tsg_og.simulation import copy_list_of_selection_points

        logger = get_logger(f'final_selection_points_{wildcards.chrom}', load_config=False)
        logger.info(f'Creating final selection points for {wildcards.chrom}')

        final_limited_result = open_pickle(input.final_limited)
        final_sp = copy_list_of_selection_points(final_limited_result)
        save_pickle(final_sp, output.selection_points)

        logger.info(f'Final selection points saved for {wildcards.chrom}')


rule final_loci_widths:
    input:
        data_file=os.path.join(loci_results_dir, 'data_per_length_scale', '{chrom}.pickle'),
        selection_points=os.path.join(analysis_dir, '{chrom}', 'final_selection_points.pickle')
    output:
        widths=os.path.join(analysis_dir, '{chrom}', 'final_loci_widths.pickle')
    log:
        os.path.join(loci_results_dir, 'logs', 'final_loci_widths_{chrom}.log')
    run:
        import spice
        from spice.utils import get_logger, open_pickle
        from spice.tsg_og.detection import infer_loci_widths

        logger = get_logger(f'final_loci_widths_{wildcards.chrom}', load_config=False)
        logger.info(f'Running final_loci_widths for {wildcards.chrom}')

        data_per_length_scale = open_pickle(input.data_file)
        selection_points = open_pickle(input.selection_points)

        infer_loci_widths(
            cur_chrom=wildcards.chrom,
            final_selection_points=selection_points,
            loci_results_dir=loci_results_dir,
            data_per_length_scale=data_per_length_scale,
            N_bootstrap=N_bootstrap,
            num_bootstrap_iterations=200,
            max_pos_change=1e5,
            max_deviation=0.00001,
            num_optimization_iterations=1_000,
            n_jobs=-1,
            calc_new_filename=output.widths
        )

        logger.info(f'Final loci widths complete for {wildcards.chrom}')


rule combine:
    input:
        selection_points=expand(
            os.path.join(analysis_dir, '{chrom}', 'final_selection_points.pickle'),
            chrom=CHROMOSOMES
        ),
        loci_widths=expand(
            os.path.join(analysis_dir, '{chrom}', 'final_loci_widths.pickle'),
            chrom=CHROMOSOMES
        )
    output:
        tsv=os.path.join(loci_results_dir, 'final_loci_detection.tsv'),
        summary=os.path.join(loci_results_dir, 'summary.txt'),
        filtered_sp=os.path.join(loci_results_dir, 'detection', 'final_loci_detection_filtered.pickle'),
        filtered_widths=os.path.join(loci_results_dir, 'detection', 'final_loci_detection_filtered_widths.pickle')
    log:
        os.path.join(loci_results_dir, 'logs', 'combine.log')
    run:
        import spice
        from spice.utils import get_logger, save_pickle
        from spice.main_loci_functions import combine_loci

        logger = get_logger('combine', load_config=False)
        logger.info(f'Combining all loci detection results for {name}')

        cur_loci_cfg = config['loci_detection']
        final_loci_df, filtered_sp, filtered_widths = combine_loci(
            loci_results_dir=loci_results_dir,
            processed_events=final_events_df,
            calculate_p_value=cur_loci_cfg.get('calculate_p_value', True),
            p_values_N_random=cur_loci_cfg.get('p_values_N_random', 1000),
            p_values_N_iterations=cur_loci_cfg.get('p_values_N_iterations', 1000),
            post_p_value_N_iterations=cur_loci_cfg.get('post_p_value_N_iterations', 25_000),
            p_value_threshold=cur_loci_cfg.get('p_value_threshold', 0.05),
            overwrite=False,
            mode='detection',
        )

        final_loci_df.to_csv(output.tsv, sep='\t', index=True)
        save_pickle(filtered_sp, output.filtered_sp)
        save_pickle(filtered_widths, output.filtered_widths)

        with open(output.summary, 'w') as f:
            f.write(f'Loci Detection De-Novo Summary\n')
            f.write(f'Project: {name}\n')
            f.write(f'Analysis directory: {loci_results_dir}\n')
            f.write(f'Chromosomes processed: {len(CHROMOSOMES)}\n')
            f.write(f'Chromosomes: {", ".join(CHROMOSOMES)}\n')
            f.write(f'Total loci detected: {len(final_loci_df)}\n')
            f.write(f'\nResults saved to: {output.tsv}\n')

        logger.info(f'Summary written to {output.summary}')
